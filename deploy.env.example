# Copiar a deploy.env y completar (deploy.env está en .gitignore)

# --- VPS (transferencia de imágenes por SSH) ---
VPS_HOST=5.189.187.169
VPS_USER=root
# Opcional: ruta a clave SSH
# VPS_SSH_KEY=~/.ssh/id_rsa

# Arquitectura del VPS (Contabo suele ser amd64)
DOCKER_PLATFORM=linux/amd64

# Nombres de imagen en el Docker del VPS (tras docker load)
PRIORA_API_IMAGE=priora-api
PRIORA_WEB_IMAGE=priora-web
IMAGE_TAG=latest

# --- Coolify API (redeploy tras subir imágenes) ---
COOLIFY_URL=https://coolify.ceapps.top
# Settings → API → Create Token (permiso deploy)
COOLIFY_TOKEN=

# UUIDs de las apps en Coolify (creadas con tipo Docker Image)
PRIORA_API_APP_UUID=arwyqa5vgjb1bp1yxz6pf3ma
PRIORA_WEB_APP_UUID=svwgcroypeuxqb71dq9s9ygw

# --- Opcional: registry en lugar de SSH ---
# DEPLOY_METHOD=registry
# REGISTRY=ghcr.io/tu-usuario
# REGISTRY_USER=tu-usuario
# REGISTRY_TOKEN=ghp_...

#!/usr/bin/env bash
# Arranca API + web en una ventana tmux con split horizontal (arriba/abajo).
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"
SESSION="${PRIORA_TMUX_SESSION:-priora}"
WINDOW="${PRIORA_TMUX_WINDOW:-dev}"

if ! command -v tmux >/dev/null 2>&1; then
  echo "tmux no está instalado."
  echo "  macOS: brew install tmux"
  exit 1
fi

if [ ! -x "$ROOT/scripts/dev.sh" ]; then
  chmod +x "$ROOT/scripts/dev.sh"
fi

launch_split() {
  local target="$1"
  # Arriba: backend | Abajo: frontend (split-window -v = divisor horizontal)
  tmux send-keys -t "$target" "cd '$ROOT' && exec ./scripts/dev.sh api" C-m
  tmux split-window -v -t "$target"
  tmux send-keys -t "$target" "cd '$ROOT' && exec ./scripts/dev.sh web" C-m
  tmux select-layout -t "$target" even-vertical
  tmux select-pane -t "${target}.0"
}

if [ -n "${TMUX:-}" ]; then
  tmux new-window -n "$WINDOW"
  target="$(tmux display-message -p '#{session_name}:#{window_index}')"
  launch_split "$target"
  echo "Ventana tmux '$WINDOW' lista (api ↑ / web ↓)."
  exit 0
fi

if tmux has-session -t "=$SESSION" 2>/dev/null; then
  tmux new-window -t "=$SESSION" -n "$WINDOW"
  launch_split "$SESSION:$WINDOW"
  exec tmux attach-session -t "=$SESSION"
fi

tmux new-session -d -s "$SESSION" -n "$WINDOW"
launch_split "$SESSION:$WINDOW"
echo "Sesión tmux '$SESSION' lista → http://127.0.0.1:5190 (o priora.localhost:8080 con proxy)"
exec tmux attach-session -t "=$SESSION"

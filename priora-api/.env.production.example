# Producción — priora.ceapps.top
# Copiar a .env en Coolify o definir como variables de entorno del contenedor.

DATABASE_URL=sqlite:/app/data/priora.db?mode=rwc
JWT_SECRET=generar-un-secreto-largo-y-aleatorio
HOST=0.0.0.0
PORT=3000
FRONTEND_URL=https://priora.ceapps.top

# Desactivar helpers de desarrollo en producción
DEV_AUTH=false
DEV_IMPERSONATION=false
SEED_DEMO_DATA=false

# Google OAuth — registrar en Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://priora.ceapps.top/api/auth/google/callback
